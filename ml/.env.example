# ml/.env — local copy is gitignored. Mirror these keys in Railway env
# vars for the ml service.

# Open-Meteo customer plan key (lowercase `apikey` query param).
OPENMETEO_APIKEY=

# Postgres connection string for the daily refresher upload step.
DATABASE_URL=

# --- Bedrock (briefing generator) ---------------------------------------
# Long-term Bedrock bearer token. Scoped to bedrock-runtime; treat as a
# secret of equivalent sensitivity to an IAM secret access key. boto3
# picks this up natively for the bedrock-runtime service.
AWS_BEARER_TOKEN_BEDROCK=

# AWS region hosting the Gemma 3 27B model. Default is us-east-1.
AWS_REGION=us-east-1

# Bedrock model ID. Verify access + exact ID before wiring.
BEDROCK_MODEL_ID=google.gemma-3-27b-instruct-v1:0
